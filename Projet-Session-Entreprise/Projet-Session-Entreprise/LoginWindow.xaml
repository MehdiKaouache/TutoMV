<Window x:Class="Projet_Session_Entreprise.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Authentification" Height="350" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Border Background="White" CornerRadius="10" Padding="20">
            <StackPanel>

                <TextBlock Text="Connexion"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 20"/>

                <TextBlock Text="DA" FontWeight="SemiBold" Margin="0 0 0 5"/>
                <TextBox x:Name="txtDA" Height="30" Margin="0 0 0 15"/>

                <TextBlock Text="Mot de passe" FontWeight="SemiBold" Margin="0 0 0 5"/>
                <PasswordBox x:Name="txtPassword" Height="30" Margin="0 0 0 20"/>

                <Button Content="Se connecter"
                        Height="35"
                        Background="#3498DB"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="Login_Click"/>

               

            </StackPanel>
        </Border>
    </Grid>
</Window>