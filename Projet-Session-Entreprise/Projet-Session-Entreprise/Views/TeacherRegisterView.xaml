<UserControl x:Class="Projet_Session_Entreprise.Views.TeacherRegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource MainBG}">
    <Grid>
        <Border Style="{StaticResource CardStyle}" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="TutoMV" FontSize="36" FontWeight="Bold" Foreground="{StaticResource PrimaryMauve}" TextAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Portail Enseignant - Étape 1" FontSize="18" Foreground="{StaticResource SuccessGreen}" TextAlignment="Center" Margin="0,0,0,25"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Nom" Foreground="{StaticResource SubText}" Margin="5,0,0,5"/>
                        <TextBox x:Name="txtName"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Prénom" Foreground="{StaticResource SubText}" Margin="5,0,0,5"/>
                        <TextBox x:Name="txtFirstName"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Numéro DA (7 chiffres)" Foreground="{StaticResource SubText}" Margin="5,15,0,5"/>
                <TextBox x:Name="txtDA"/>

                <TextBlock Text="Moyenne générale (%)" Foreground="{StaticResource SubText}" Margin="5,15,0,5"/>
                <TextBox x:Name="txtGPA"/>

                <TextBlock Text="Mot de passe (min. 8 car.)" Foreground="{StaticResource SubText}" Margin="5,15,0,5"/>
                <PasswordBox x:Name="txtPassword"/>

                <Button x:Name="btnSignUp" Content="Continuer vers les détails" Style="{StaticResource ActionButton}" Margin="0,30,0,0" Click="BtnSignUp_Click"/>
                <Button x:Name="btnCancel" Content="Annuler" Style="{StaticResource LinkButton}" Margin="0,10,0,0" Click="BtnCancel_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>