<UserControl x:Class="Projet_Session_Entreprise.Views.RequeteRoleTuteurView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource MainBG}">
    <Grid>
        <Border Style="{StaticResource CardStyle}" Width="500" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Détails du profil Tuteur" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryMauve}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Configurez vos matières et disponibilités" Foreground="{StaticResource SubText}" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <TextBlock Text="Matières d'expertise" Foreground="{StaticResource SubText}" Margin="5,0,0,5"/>
                <ListBox x:Name="lstSubjects" SelectionMode="Multiple" Height="80" Background="#1A1A1A" Foreground="White" BorderBrush="{StaticResource BorderColor}">
                    <ListBoxItem Content="Mathématiques"/>
                    <ListBoxItem Content="Informatique"/>
                    <ListBoxItem Content="Français"/>
                    <ListBoxItem Content="Anglais"/>
                </ListBox>

                <TextBlock Text="Disponibilité principale" Foreground="{StaticResource SubText}" Margin="5,15,0,5"/>
                <ComboBox x:Name="cmbAvailability" Height="40">
                    <ComboBoxItem Content="Lundi" IsSelected="True"/>
                    <ComboBoxItem Content="Mardi"/>
                    <ComboBoxItem Content="Mercredi"/>
                    <ComboBoxItem Content="Jeudi"/>
                    <ComboBoxItem Content="Vendredi"/>
                </ComboBox>

                <TextBlock Text="Cours spécifique visé" Foreground="{StaticResource SubText}" Margin="5,15,0,5"/>
                <TextBox x:Name="txtCourseTargeted" Text="{Binding SelectedCourse}"/>

                <TextBlock Text="Note obtenue (%)" Foreground="{StaticResource SubText}" Margin="5,15,0,5"/>
                <TextBox x:Name="txtGradeCourse" Text="{Binding EnteredGrade}"/>

                <Button Content="Finaliser mon inscription" Style="{StaticResource ActionButton}" Margin="0,30,0,15" Click="BtnFinalize_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>