<UserControl x:Class="Projet_Session_Entreprise.Views.SidebarControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource SurfaceColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="25,40,25,40">
            <TextBlock Text="TutoMV" FontSize="26" FontWeight="ExtraBold" Foreground="{StaticResource PrimaryMauve}"/>
            <Border Height="2" Background="{StaticResource PrimaryMauve}" Width="40" HorizontalAlignment="Left" Margin="2,10,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="15,0">
            <Button Content="Tableau de bord" Click="btnHome_Click" Style="{StaticResource MenuButton}"/>
            <Button x:Name="btnSearch" Content="Rechercher un tuteur" Click="btnSearch_Click" Style="{StaticResource MenuButton}"/>
            <Button x:Name="btnBecomeTutor" Content="Devenir Tuteur" Click="btnBecomeTutor_Click" Style="{StaticResource MenuButton}"/>
            <Button x:Name="btnManageRequests" Content="Gérer les demandes" Click="btnAppointments_Click" Style="{StaticResource MenuButton}" Visibility="Collapsed"/>
            <Button Content="Mes rendez-vous" Click="btnAppointments_Click" Style="{StaticResource MenuButton}"/>
            <Button Content="Mon Profil" Click="btnProfile_Click" Style="{StaticResource MenuButton}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="15,0,15,30">
            <Separator Background="{StaticResource BorderColor}" Margin="0,0,0,20"/>
            <Button Content="Déconnexion" Click="btnLogInOrOut" Style="{StaticResource MenuButton}" Foreground="{StaticResource DangerRed}"/>
        </StackPanel>
    </Grid>
</UserControl>