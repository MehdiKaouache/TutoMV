<Window x:Class="Projet_Session_Entreprise.Views.RegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:Projet_Session_Entreprise.ViewModels"
        mc:Ignorable="d"
        Title="Inscription - TutoMV" 
        Height="650" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">
    <Grid>
        <Border Background="White" 
                CornerRadius="15" 
                Width="450" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center" 
                Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="TutoMV" FontSize="36" FontWeight="Bold" Foreground="#2C3E50" TextAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Créer un compte" FontSize="18" Foreground="#7F8C8D" TextAlignment="Center" Margin="0,0,0,30"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Nom" FontWeight="SemiBold" Foreground="#34495E" Margin="5,0,0,5"/>
                        <TextBox x:Name="txtName" Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="5"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Prénom" FontWeight="SemiBold" Foreground="#34495E" Margin="5,0,0,5"/>
                        <TextBox x:Name="txtFirstName" Text="{Binding Prenom, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="5"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="no. DA" FontWeight="SemiBold" Foreground="#34495E" Margin="5,15,0,5"/>
                <TextBox x:Name="txtDA" Text="{Binding NoDa, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="5"/>

                <TextBlock Text="Type d'utilisateur" FontWeight="SemiBold" Foreground="#34495E" Margin="5,15,0,5"/>
                <ComboBox x:Name="cmbUserType" Height="35" 
                          ItemsSource="{Binding Roles}" 
                          SelectedItem="{Binding RoleSelectionne}"/>

                <TextBlock Text="Moyenne générale (%)" FontWeight="SemiBold" Foreground="#34495E" Margin="5,15,0,5"/>
                <TextBox x:Name="txtGPA" Height="35" Padding="5"/>

                <TextBlock Text="Mot de passe" FontWeight="SemiBold" Foreground="#34495E" Margin="5,15,0,5"/>
                <PasswordBox x:Name="txtPassword" Height="35" Padding="5"/>

                <Button x:Name="btnSignUp" Height="45" Content="S'inscrire" 
                        Background="#2ECC71" Foreground="White" FontSize="16" 
                        FontWeight="Bold" Margin="0,30,0,0" 
                        Click="btnSignUp_Click" Cursor="Hand"/>

                <Button x:Name="btnCancel" Content="Retour à la connexion" 
                        Background="Transparent" Foreground="#3498DB" 
                        Margin="0,10,0,0" BorderThickness="0" 
                        Click="btnCancel_Click" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>