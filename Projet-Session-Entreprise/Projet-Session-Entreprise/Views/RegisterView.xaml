<Window x:Class="Projet_Session_Entreprise.Views.RegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projet_Session_Entreprise"
        Title="Register"
        mc:Ignorable="d"
        Height="500" Width="450"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,20,0,10">
            <TextBlock Text="TutoMV"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       TextAlignment="Center"/>
            <TextBlock Text="Créer un compte"
                       FontSize="18"
                       Foreground="#7F8C8D"
                       TextAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="40,0,40,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Nom" FontWeight="SemiBold" Margin="5,0,0,0"/>
                    <TextBox x:Name="txtName"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Prénom" FontWeight="SemiBold" Margin="5,0,0,0"/>
                    <TextBox x:Name="txtFirstName"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                <TextBlock Text="Numéro DA" FontWeight="SemiBold" Margin="5,0,0,0"/>
                <TextBox x:Name="txtDA"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                <TextBlock Text="Type de compte" FontWeight="SemiBold" Margin="5,0,0,0"/>
                <ComboBox x:Name="cmbUserType" Height="30" Margin="5">
                    <ComboBoxItem Content="Étudiant" IsSelected="True"/>
                    <ComboBoxItem Content="Enseignant"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,10,0,0">
                <TextBlock Text="Moyenne générale (%)" FontWeight="SemiBold" Margin="5,0,0,0"/>
                <TextBox x:Name="txtGPA"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,10,0,0">
                <TextBlock Text="Mot de passe" FontWeight="SemiBold" Margin="5,0,0,0"/>
                <PasswordBox x:Name="txtPassword" Height="30" Margin="5" Padding="5"/>
            </StackPanel>

            <Button x:Name="btnSignUp" 
                    Grid.Row="5"
                    Content="S'inscrire" 
                    Width="200" Height="40" 
                    Margin="0,20,0,0"
                    Background="#2ECC71"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"/>
        </Grid>
    </Grid>
</Window>