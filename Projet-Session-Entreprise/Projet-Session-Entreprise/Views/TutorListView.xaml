<Window x:Class="Projet_Session_Entreprise.Views.TutorListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Liste des Tuteurs" Height="500" Width="800"
        WindowStartupLocation="CenterScreen" Background="#F4F6F8">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Réserver une séance" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="10">
            <DataGrid x:Name="dgTutors" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="None">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                    <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="*"/>
                    <DataGridTextColumn Header="Matière" Binding="{Binding Subject}" Width="*"/>
                    <DataGridTextColumn Header="Dispo" Binding="{Binding Availability}" Width="*"/>
                    <DataGridTemplateColumn Header="Action" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Réserver" Click="Reserve_Click" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>