<UserControl x:Class="Projet_Session_Entreprise.Views.TutorListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,25">
            <TextBlock Text="Trouver un tuteur" FontSize="32" FontWeight="Bold" Foreground="{StaticResource MainText}"/>
            <TextBlock Text="Parcourez la liste des experts disponibles pour vous aider." Foreground="{StaticResource SubText}" Margin="0,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid x:Name="dgTutors" ItemsSource="{Binding Tuteurs}" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="PRÉNOM" Binding="{Binding Prenom}" Width="*"/>
                    <DataGridTextColumn Header="NOM" Binding="{Binding Nom}" Width="*"/>
                    <DataGridTextColumn Header="SPÉCIALITÉ" Binding="{Binding Subject}" Width="*"/>
                    <DataGridTemplateColumn Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Prendre RDV" Style="{StaticResource ActionButton}" 
                                        Height="32" Margin="10,0" Click="Reserve_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>