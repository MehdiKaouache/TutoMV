<Window x:Class="Projet_Session_Entreprise.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Teacher Manager" Height="500" Width="900"
        Background="#F4F6F8">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Text="TutoMV"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0 0 0 20"/>

        <!-- FORM -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="0 0 0 15">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- NAME -->
                <StackPanel Grid.Column="0" Margin="10">
                    <TextBlock Text="Name" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtName"/>
                </StackPanel>

                <!-- SUBJECT -->
                <StackPanel Grid.Column="1" Margin="10">
                    <TextBlock Text="Subject" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtSubject"/>
                </StackPanel>

                <!-- AVAILABILITY (ComboBox) -->
                <StackPanel Grid.Column="2" Margin="10">
                    <TextBlock Text="Availability" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cmbAvailability" Height="30">
                        <ComboBoxItem Content="Monday"/>
                        <ComboBoxItem Content="Tuesday"/>
                        <ComboBoxItem Content="Wednesday"/>
                        <ComboBoxItem Content="Thursday"/>
                        <ComboBoxItem Content="Friday"/>
                    </ComboBox>
                </StackPanel>

            </Grid>
        </Border>

        <!-- BUTTONS + GRID -->
        <Grid Grid.Row="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- BUTTONS -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0 0 0 10">

                <Button Content="Add"
                        Width="120"
                        Height="35"
                        Margin="5"
                        Background="#2ECC71"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="Add_Click"/>

                <Button Content="Update"
                        Width="120"
                        Height="35"
                        Margin="5"
                        Background="#3498DB"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="Update_Click"/>

                <Button Content="Delete"
                        Width="120"
                        Height="35"
                        Margin="5"
                        Background="#E74C3C"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="Delete_Click"/>
            </StackPanel>

            <!-- GRID -->
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="10">

                <DataGrid x:Name="grid"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="grid_SelectionChanged"
                          RowHeight="30"
                          FontSize="14"/>
            </Border>

        </Grid>

    </Grid>
</Window>