<Window x:Class="Projet_Session_Entreprise.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:Projet_Session_Entreprise.ViewModels"
        Title="Authentification - TutoMV"
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">
	<Grid>
		<Border Background="White"
                CornerRadius="15"
                Width="400"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="30">
			<Border.Effect>
				<DropShadowEffect BlurRadius="20" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1"/>
			</Border.Effect>
			<StackPanel>
				<TextBlock Text="TutoMV" FontSize="36" FontWeight="Bold" Foreground="#2C3E50" TextAlignment="Center" Margin="0,0,0,5"/>
				<TextBlock Text="Connexion" FontSize="18" Foreground="#7F8C8D" TextAlignment="Center" Margin="0,0,0,30"/>

				<TextBlock Text="Numéro DA" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
				<TextBox x:Name="txtDA" Text="{Binding NoDa, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="5" Margin="0,0,0,20"/>

				<TextBlock Text="Mot de passe" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
				<PasswordBox x:Name="txtPassword" Height="35" Padding="5" Margin="0,0,0,30"/>

				<Button x:Name="btnConn" Height="45" Content="Se connecter" Background="#2ECC71" Foreground="White" FontSize="16" FontWeight="Bold" Click="btnConn_Click" Cursor="Hand">
					<Button.Resources>
						<Style TargetType="Border">
							<Setter Property="CornerRadius" Value="5"/>
						</Style>
					</Button.Resources>
				</Button>

				<Button x:Name="btnReg" Content="Pas encore de compte ? S'inscrire" Background="Transparent" Foreground="#3498DB" Margin="0,15,0,0" BorderThickness="0" Click="btnReg_Click" Cursor="Hand"/>

				<TextBlock Text="{Binding StatusMessage}" Foreground="#E74C3C" FontWeight="Bold" TextAlignment="Center" Margin="0,15,0,0"/>
			</StackPanel>
		</Border>
	</Grid>
</Window>