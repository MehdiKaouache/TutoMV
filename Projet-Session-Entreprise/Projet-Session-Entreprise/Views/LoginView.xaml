<Window x:Class="Projet_Session_Entreprise.LoginView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Projet_Session_Entreprise"
      Title="Authentification" Height="450" Width="450"
      WindowStartupLocation="CenterScreen"
      Background="#F4F6F8"
      ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Teacher Manager"
           FontSize="26"
           FontWeight="Bold"
           Foreground="#2C3E50"
           Grid.Column="1"
           TextAlignment="Center"/>

        <TextBlock Margin="0 43"
            Text="Connexion"
            FontSize="20"
            FontWeight="Medium"
            Foreground="#2C3E50"
            Grid.Column="1"
            TextAlignment="Center"/>

        <Grid Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- faut encore le data binding, les passwordBoxes marchent pas comme les TextBoxes normales -->
            <StackPanel Grid.Row="0" Margin="10">
                <TextBlock Text="no. DA" FontWeight="SemiBold"/>
                <TextBox x:Name="txtDA" Text="{Binding NoDa, UpdateSourceTrigger=PropertyChanged}"/> 
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="10">
                <TextBlock Text="Mot de passe" FontWeight="SemiBold"/>
                <PasswordBox x:Name="txtPassword" Height="30" Margin="5" Padding="5"/> 
            </StackPanel>

            <StackPanel Grid.Row="2">
                <Button x:Name="btnConn" 
                        Width="120" Height="30" 
                        Content="Se connecter" 
                        Margin="0 15"                         
                        Background="#2ECC71"
                        Foreground="White"
                        FontWeight="Bold"/>
            </StackPanel>

        </Grid>
    </Grid>
</Window>
