<Window x:Class="Projet_Session_Entreprise.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Authentification" Height="450" Width="450"
        WindowStartupLocation="CenterScreen" Background="#F4F6F8" ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="TutoMV" FontSize="28" FontWeight="Bold" Foreground="#2C3E50" 
                   Grid.Column="1" Margin="0,20,0,0" TextAlignment="Center"/>

        <TextBlock Text="Connexion" FontSize="18" Foreground="#7F8C8D" 
                   Grid.Column="1" Margin="0,65,0,0" TextAlignment="Center"/>

        <Grid Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="10">
                <TextBlock Text="Numéro DA" FontWeight="SemiBold"/>
                <TextBox x:Name="txtDA"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="10">
                <TextBlock Text="Mot de passe" FontWeight="SemiBold"/>
                <PasswordBox x:Name="txtPassword" Height="30" Margin="5" Padding="5"/>
            </StackPanel>

            <StackPanel Grid.Row="2">
                <Button x:Name="btnConn" Width="120" Height="30" Content="Se connecter" 
                        Margin="0 5" Background="#2ECC71" Foreground="White" 
                        FontWeight="Bold" Click="btnConn_Click"/>

                <Button x:Name="btnReg" Width="120" Height="30" Content="S'inscrire" 
                        Margin="0 5" Background="Transparent" Foreground="#3498DB" 
                        BorderThickness="0" Click="btnReg_Click" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>