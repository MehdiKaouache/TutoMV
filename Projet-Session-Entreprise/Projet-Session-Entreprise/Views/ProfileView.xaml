<Window x:Class="Projet_Session_Entreprise.Views.ProfileView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile"
        Height="700"
        Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding DA, StringFormat='Profil : {0}'}"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0 0 0 20"/>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="20"
                Margin="0 0 0 15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Bienvenue, " FontSize="18"/>
                <TextBlock Text="{Binding Prenom}" FontSize="18" FontWeight="Bold" Margin="5 0 0 0"/>
                <TextBlock Text="{Binding Nom}" FontSize="18" FontWeight="Bold" Margin="5 0 0 0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Visibility="{Binding StudentSectionVisibility}" Margin="0 0 15 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="White" CornerRadius="10" Padding="10" Margin="0 0 0 15">
                    <DataGrid ItemsSource="{Binding Tutors}"
                              SelectedItem="{Binding SelectedTutor}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*" />
                            <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="*" />
                            <DataGridTextColumn Header="Matière" Binding="{Binding Subject}" Width="*" />
                            <DataGridTextColumn Header="Dispo" Binding="{Binding Availability}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Évaluer le tuteur sélectionné" FontSize="16" FontWeight="Bold" Margin="0 0 0 10"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox Width="80" ItemsSource="{Binding RatingChoices}" SelectedItem="{Binding SelectedRating}" Height="30"/>
                            <Button Content="Ajouter Note" 
                                    Command="{Binding AddRatingCommand}"
                                    Width="120" Height="30" Margin="10 0 0 0"
                                    Background="#9B59B6" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#E67E22" Margin="0 10 0 0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="Informations Personnelles" FontSize="18" FontWeight="Bold" Margin="0 0 0 15"/>

                    <TextBlock Text="DA" Margin="0 5 0 2" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding DA}" IsReadOnly="True" Background="#F0F0F0" Height="30" Padding="5"/>

                    <TextBlock Text="Nom" Margin="0 10 0 2" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Nom}" Height="30" Padding="5"/>

                    <TextBlock Text="Prénom" Margin="0 10 0 2" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Prenom}" Height="30" Padding="5"/>

                    <StackPanel Visibility="{Binding TutorSectionVisibility}">
                        <TextBlock Text="Mes Disponibilités" Margin="0 10 0 2" FontWeight="SemiBold" Foreground="#2980B9"/>
                        <ComboBox ItemsSource="{Binding AvailabilityChoices}" 
                                  SelectedItem="{Binding SelectedAvailability}" 
                                  Height="30" Margin="0 0 0 10"/>

                        <Button Content="Enregistrer Dispos"
                                Command="{Binding SaveAvailabilityCommand}"
                                Height="35" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>