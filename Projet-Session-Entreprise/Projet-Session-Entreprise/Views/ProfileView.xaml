<Window x:Class="Projet_Session_Entreprise.Views.ProfileView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:viewmodels="clr-namespace:Projet_Session_Entreprise.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:ProfileViewModel}"
        mc:Ignorable="d"
        Title="Profil" Height="500" Width="600"
        Background="White"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Mon Profil"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"
                   HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="DA :" Margin="5" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <TextBox Grid.Row="1" Grid.Column="1"
                 Text="{Binding DA}"
                 IsReadOnly="True"
                 Background="#F0F0F0"
                 Margin="5" Height="30" Padding="5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Nom :" Margin="5" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <TextBox Grid.Row="2" Grid.Column="1"
                 Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}"
                 Margin="5" Height="30" Padding="5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Prénom :" Margin="5" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <TextBox Grid.Row="3" Grid.Column="1"
                 Text="{Binding Prenom, UpdateSourceTrigger=PropertyChanged}"
                 Margin="5" Height="30" Padding="5"/>

        <TextBlock Grid.Row="4" Grid.Column="0" 
                   Text="Disponibilités :" 
                   Margin="5" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#2980B9"
                   Visibility="{Binding IsTutor, Converter={StaticResource BoolToVis}}"/>
        <TextBox Grid.Row="4" Grid.Column="1"
                 Text="{Binding Availability, UpdateSourceTrigger=PropertyChanged}"
                 Visibility="{Binding IsTutor, Converter={StaticResource BoolToVis}}"
                 Margin="5" Height="30" Padding="5" 
                 Tag="Ex: Lundi 14h-16h"/>

        <Button Grid.Row="5" Grid.ColumnSpan="2"
                Content="Enregistrer les modifications"
                Command="{Binding SauvegarderCommand}"
                Width="200" Height="35"
                Margin="140,20,0,0"
                Background="#3498DB" Foreground="White" FontWeight="Bold"/>

        <TextBlock Grid.Row="6" Grid.ColumnSpan="2"
                   Text="{Binding StatusMessage}"
                   Foreground="#2ECC71"
                   FontWeight="Bold"
                   TextAlignment="Center"
                   Margin="10"/>

        <ItemsControl Grid.Row="7" Grid.Column="1" ItemsSource="{Binding ReviewList}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5" Padding="10" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding NomEleve}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding EtoilesString}"/>
                            <TextBlock Text="{Binding Commentaire}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </Grid>
</Window>