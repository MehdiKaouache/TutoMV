<Window x:Class="Projet_Session_Entreprise.Views.ProfileView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile" Height="750" Width="950" WindowStartupLocation="CenterScreen" Background="#F4F6F8">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding DA, StringFormat='Profil : {0}'}" FontSize="28" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Bienvenue, " FontSize="18"/>
                <TextBlock Text="{Binding Prenom}" FontSize="18" FontWeight="Bold" Margin="5,0,0,0"/>
                <TextBlock Text="{Binding Nom}" FontSize="18" FontWeight="Bold" Margin="5,0,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Mes Rendez-vous" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="#273C75"/>
                        <DataGrid ItemsSource="{Binding MyAppointments}" AutoGenerateColumns="False" IsReadOnly="True" Height="150">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding DateRDV, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="*"/>
                                <DataGridTextColumn Header="Statut" Binding="{Binding Status}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Grid Visibility="{Binding StudentSectionVisibility}">
                    <Button Content="PRENDRE UN RENDEZ-VOUS" Click="SearchTutor_Click" Height="45" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
                </Grid>
            </StackPanel>

            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="Informations Personnelles" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                    <TextBlock Text="Nom" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Nom}" Height="30" Margin="0,5,0,10"/>
                    <TextBlock Text="Prénom" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Prenom}" Height="30" Margin="0,5,0,10"/>

                    <StackPanel Visibility="{Binding TutorSectionVisibility}">
                        <TextBlock Text="Mes Disponibilités" FontWeight="SemiBold" Margin="0,10,0,5"/>
                        <ComboBox ItemsSource="{Binding AvailabilityChoices}" SelectedItem="{Binding SelectedAvailability}" Height="30" Margin="0,0,0,10"/>
                        <Button Content="Enregistrer Dispos" Command="{Binding SaveAvailabilityCommand}" Height="35" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>