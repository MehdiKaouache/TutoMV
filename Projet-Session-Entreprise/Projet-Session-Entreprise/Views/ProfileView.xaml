<UserControl x:Class="Projet_Session_Entreprise.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding DA, StringFormat='Profil : {0}'}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource MainText}" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Bienvenue, " FontSize="18" Foreground="{StaticResource SubText}"/>
                <TextBlock Text="{Binding Prenom}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryMauve}" Margin="5,0,0,0"/>
                <TextBlock Text="{Binding Nom}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryMauve}" Margin="5,0,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Mes Rendez-vous" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource PrimaryMauve}"/>
                        <DataGrid ItemsSource="{Binding MyAppointments}" AutoGenerateColumns="False" IsReadOnly="True" Height="200"
                                  Background="Transparent" BorderThickness="0" Foreground="{StaticResource MainText}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding DateRDV, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="*"/>
                                <DataGridTextColumn Header="Statut" Binding="{Binding Status}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Informations" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource MainText}"/>

                    <TextBlock Text="DA" Foreground="{StaticResource SubText}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding DA}" IsReadOnly="True" Opacity="0.6" Margin="0,0,0,15"/>

                    <TextBlock Text="Nom" Foreground="{StaticResource SubText}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Nom}" Margin="0,0,0,15"/>

                    <TextBlock Text="Prénom" Foreground="{StaticResource SubText}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Prenom}" Margin="0,0,0,15"/>

                    <StackPanel Visibility="{Binding TutorSectionVisibility}">
                        <TextBlock Text="Disponibilités" Foreground="{StaticResource SubText}" Margin="0,10,0,5"/>
                        <Button Content="Enregistrer les modifications" Style="{StaticResource ActionButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>