<Window x:Class="Projet_Session_Entreprise.Views.ProfileView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile"
        Height="650"
        Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding PageTitle}"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0 0 0 20"/>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="20"
                Margin="0 0 0 15">
            <StackPanel>
                <TextBlock Text="{Binding WelcomeText}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0 0 0 10"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">

            <!-- STUDENT SECTION -->
            <Grid Visibility="{Binding StudentSectionVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="White"
                        CornerRadius="10"
                        Padding="10"
                        Margin="0 0 0 15">
                    <DataGrid ItemsSource="{Binding Tutors}"
                              SelectedItem="{Binding SelectedTutor}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              RowHeight="30"
                              FontSize="14"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"
                                                Binding="{Binding Nom}"
                                                Width="*" />
                            <DataGridTextColumn Header="First Name"
                                                Binding="{Binding Prenom}"
                                                Width="*" />
                            <DataGridTextColumn Header="Subject"
                                                Binding="{Binding Subject}"
                                                Width="*" />
                            <DataGridTextColumn Header="Availability"
                                                Binding="{Binding Availability}"
                                                Width="*" />
                            <DataGridTextColumn Header="Rating"
                                                Binding="{Binding AverageRating, StringFormat={}{0:0.0}}"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Row="1"
                        Background="White"
                        CornerRadius="10"
                        Padding="15">
                    <StackPanel>
                        <TextBlock Text="Rate selected tutor"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0 0 0 10"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Rating:"
                                       VerticalAlignment="Center"
                                       Margin="0 0 10 0"/>

                            <ComboBox Width="100"
                                      Height="30"
                                      SelectedValuePath="Content"
                                      SelectedValue="{Binding SelectedRating, Mode=TwoWay}">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="4"/>
                                <ComboBoxItem Content="5"/>
                            </ComboBox>

                            <Button Content="Add Rating"
                                    Width="120"
                                    Height="35"
                                    Margin="15 0 0 0"
                                    Background="#9B59B6"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Command="{Binding AddRatingCommand}"/>
                        </StackPanel>

                        <TextBlock Text="{Binding RatingInfo}"
                                   Margin="0 15 0 0"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#2C3E50"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- TUTOR SECTION -->
            <Grid Visibility="{Binding TutorSectionVisibility}">
                <Border Background="White"
                        CornerRadius="10"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Modify your availability"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0 0 0 20"/>

                        <TextBlock Text="Name" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TutorFullName}"
                                   Margin="0 5 0 15"
                                   FontSize="14"/>

                        <TextBlock Text="Subject" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TutorSubject}"
                                   Margin="0 5 0 15"
                                   FontSize="14"/>

                        <TextBlock Text="Availability" FontWeight="SemiBold"/>
                        <ComboBox Height="30"
                                  Margin="0 0 0 20"
                                  SelectedValuePath="Content"
                                  SelectedValue="{Binding SelectedAvailability, Mode=TwoWay}">
                            <ComboBoxItem Content="Monday"/>
                            <ComboBoxItem Content="Tuesday"/>
                            <ComboBoxItem Content="Wednesday"/>
                            <ComboBoxItem Content="Thursday"/>
                            <ComboBoxItem Content="Friday"/>
                        </ComboBox>

                        <Button Content="Save Availability"
                                Height="35"
                                Background="#3498DB"
                                Foreground="White"
                                FontWeight="Bold"
                                Command="{Binding SaveAvailabilityCommand}"/>

                        <TextBlock Text="{Binding TutorInfo}"
                                   Margin="0 15 0 0"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#2C3E50"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>